{
  "manifest_version": 3,
  "name": "Robot Monitoramento Analises",
  "version": "0.4.0",
  "description": "Ferramenta para inspeção e automação do BSIT.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://jatai.bsit-br.com.br/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Habitese Robot"
  },
  "content_scripts": [
    {
      "matches": [
        "http://jatai.bsit-br.com.br/*"
      ],
    "js": [
      "js/core/storage.js",
      "js/core/distribution.js",
      "js/bsit/inspector.js",
      "content.js"
    ],
      "run_at": "document_idle"
    }
  ]
}